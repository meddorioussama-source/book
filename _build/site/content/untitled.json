{"version":3,"kind":"Notebook","sha256":"6d494c73f2ed2dc577f44611c2351a9fb831c8e615d80fd53e17b8f27dcac0bb","slug":"untitled","location":"/Untitled.ipynb","dependencies":[],"frontmatter":{"title":"","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"id":"oussama","name":"oussama"}],"exports":[{"format":"ipynb","filename":"Untitled.ipynb","url":"/Untitled-8b2f67e98fa5d9770e04d80a4b068cbe.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"children":[{"type":"text","value":"national higer schoole of autonoumes systems","key":"G4SQHoyYoM"}],"identifier":"national-higer-schoole-of-autonoumes-systems","label":"national higer schoole of autonoumes systems","html_id":"national-higer-schoole-of-autonoumes-systems","implicit":true,"key":"Zk9enRo7nM"},{"type":"heading","depth":1,"children":[{"type":"text","value":"home work of linear control systems","key":"a1rkerbt7l"}],"identifier":"home-work-of-linear-control-systems","label":"home work of linear control systems","html_id":"home-work-of-linear-control-systems","implicit":true,"key":"H2TOii190o"},{"type":"heading","depth":2,"children":[{"type":"text","value":"oussama meddouri,mosif benaini","key":"P39SvpFgeQ"}],"identifier":"oussama-meddouri-mosif-benaini","label":"oussama meddouri,mosif benaini","html_id":"oussama-meddouri-mosif-benaini","implicit":true,"key":"qZuk3sLTsB"},{"type":"heading","depth":1,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[],"key":"u9oPWHPfr9"},{"type":"heading","depth":1,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[],"key":"Cqtjk8MWkL"},{"type":"heading","depth":1,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[],"key":"LFd6UdgZMt"},{"type":"heading","depth":1,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[],"key":"zGjQPOZQwi"},{"type":"heading","depth":1,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[],"key":"RvbXCbLxAc"},{"type":"heading","depth":1,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[],"key":"O6Bxr5WBKj"},{"type":"heading","depth":3,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Setup","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"WO8J4r7DFd"}],"identifier":"setup","label":"Setup","html_id":"setup","implicit":true,"key":"OE2eIBjeCl"}],"key":"zV4b2ZJVGE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom scipy import signal\nimport sympy as sp\nimport control as ct","key":"ZASct2ut3e"},{"type":"outputs","id":"Lkn0VD4SlbyPjEezrMBhC","children":[],"key":"szZiXMPoIP"}],"key":"ZtjwUMT1jh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Parameters\nK = 0.5  # Nm/A\nJ = 0.02 # kg*m^2\nb = 0.1  # Nms\nL = 0.5  # H\nR = 1    # Ohm","key":"NA94XCtl64"},{"type":"outputs","id":"QsC_pWHF8c-6smDCo-m2t","children":[],"key":"QAdZcOR0av"}],"key":"gEzXRBdANV"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Modle representation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GfTUU2S9qT"}],"identifier":"modle-representation","label":"Modle representation","html_id":"modle-representation","implicit":true,"key":"uj1n1UhKMd"}],"key":"uRqImvtsnl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"print(\"--- 1. Model Representation ---\")\n\n# Transfer Function: G(s) = K / (s * ((Js + b)(Ls + R) + K^2))\n# Denominator: s * (JLs^2 + (JR + bL)s + bR + K^2)\n# = JLs^3 + (JR + bL)s^2 + (bR + K^2)s\n\nnum = [K]\nden = [ (J+b)*(L+R), K**2]\nG = ct.TransferFunction(num, den)\nprint(f\"Transfer Function G(s):\\n{G}\")","key":"UTWV5cBgIS"},{"type":"outputs","id":"f6UMMnkFEqjI8JR67ah7-","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"--- 1. Model Representation ---\nTransfer Function G(s):\n<TransferFunction>: sys[0]\nInputs (1): ['u[0]']\nOutputs (1): ['y[0]']\n\n       0.5\n  -------------\n  0.18 s + 0.25\n"},"children":[],"key":"rn5sb4MUzg"}],"key":"PmMPeZ1wfF"}],"key":"oxlPkWZvVd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# State-Space Representation\n# Let x1 = theta, x2 = theta_dot, x3 = i\n# d/dt [x1; x2; x3] = [0 1 0; 0 -b/J K/J; 0 -K/L -R/L] [x1; x2; x3] + [0; 0; 1/L] V\n# y = [1 0 0] [x1; x2; x3]\nA = [[0, 1, 0],\n     [0, -b/J, K/J],\n     [0, -K/L, -R/L]]\nB = [[0], [0], [1/L]]\nC = [[1, 0, 0]]\nD = [[0]]\nsys_ss = ct.ss(A, B, C, D)\nprint(f\"\\nState-Space Representation:\\nA = {A}\\nB = {B}\\nC = {C}\\nD = {D}\")","key":"afmm5QSuEQ"},{"type":"outputs","id":"xiJ99uhaiYHCXq-mx_QGY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\nState-Space Representation:\nA = [[0, 1, 0], [0, -5.0, 25.0], [0, -1.0, -2.0]]\nB = [[0], [0], [2.0]]\nC = [[1, 0, 0]]\nD = [[0]]\n"},"children":[],"key":"f6KDwpzUQ5"}],"key":"CER9vrZP0J"}],"key":"Y5NyBfz6r1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.figure(figsize=(8, 6))\nct.pole_zero_plot(G)\nplt.title('Pole-Zero Map')\nplt.grid(True)\nplt.savefig('pole_zero_map.png')","key":"oMwcYKP9FW"},{"type":"outputs","id":"txhX3YrSV4BW3egcaXKXB","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"30a5aad7bbb864d6697a0fae7d1e7519","path":"/30a5aad7bbb864d6697a0fae7d1e7519.png"},"text/plain":{"content":"<Figure size 800x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Ia5orWF2pi"}],"key":"yVFi2FGrjx"}],"key":"VhfWKkfJcx"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Time response analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"V5PAqZPsma"}],"identifier":"time-response-analysis","label":"Time response analysis","html_id":"time-response-analysis","implicit":true,"key":"xujXsSwqkF"}],"key":"pVK0UycleG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Step Response\n# Since it's an integrator, the position will increase indefinitely.\n# Let's simulate for a finite time.\nt = np.linspace(0, 20, 1000)\nt, y = ct.step_response(G, T=t)\nplt.figure(figsize=(8, 6))\nplt.plot(t, y)\nplt.title('Step Response (Angular Position)')\nplt.xlabel('Time (s)')\nplt.ylabel('Position (rad)')\nplt.grid(True)\nplt.savefig('step_response.png')\n","key":"ohzdv1zJxN"},{"type":"outputs","id":"KtEQC24df669ccUSldiOU","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"7d39f2737c73618dff0a5d7791a3da31","path":"/7d39f2737c73618dff0a5d7791a3da31.png"},"text/plain":{"content":"<Figure size 800x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"cu9fvlgYWx"}],"key":"C0hE0MKACz"}],"key":"rLDFgUx3kY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Velocity Step Response (G_vel = s * G)\nG_vel = ct.TransferFunction([K], [J*L, J*R + b*L, b*R + K**2])\nt_vel, y_vel = ct.step_response(G_vel, T=t)\nplt.figure(figsize=(8, 6))\nplt.plot(t_vel, y_vel)\nplt.title('Step Response (Angular Velocity)')\nplt.xlabel('Time (s)')\nplt.ylabel('Velocity (rad/s)')\nplt.grid(True)\nplt.savefig('velocity_step_response.png')","key":"Nyzt7df7HV"},{"type":"outputs","id":"PAW1NRUkRQiKNphxN3nbL","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"214a40c96bd2c1db6b07330275653bd3","path":"/214a40c96bd2c1db6b07330275653bd3.png"},"text/plain":{"content":"<Figure size 800x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"udOlIrcKhT"}],"key":"tBK6iqcvJR"}],"key":"ZNh9PZR6LY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Impulse Response\nt_imp, y_imp = ct.impulse_response(G, T=t)\nplt.figure(figsize=(8, 6))\nplt.plot(t_imp, y_imp)\nplt.title('Impulse Response (Angular Position)')\nplt.xlabel('Time (s)')\nplt.ylabel('Position (rad)')\nplt.grid(True)\nplt.savefig('impulse_response.png')","key":"skoNBWznSo"},{"type":"outputs","id":"gqWr-8fiva2iE8RFmyUpF","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"06da6d11c5d39d3cd4a286d0925cc8ed","path":"/06da6d11c5d39d3cd4a286d0925cc8ed.png"},"text/plain":{"content":"<Figure size 800x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"GHdvd7mgAB"}],"key":"WzHM7kyoIN"}],"key":"b5v7hyNDy7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Performance Characteristics for Velocity\ninfo_vel = ct.step_info(G_vel)\nprint(\"Velocity Step Response Characteristics:\")\nprint(f\"Rise Time: {info_vel['RiseTime']:.4f} s\")\nprint(f\"Settling Time: {info_vel['SettlingTime']:.4f} s\")\nprint(f\"Overshoot: {info_vel['Overshoot']:.4f} %\")\nprint(f\"Steady-state value: {y_vel[-1]:.4f}\")\n","key":"vNeC8iy4i3"},{"type":"outputs","id":"zAZ9bh8_zNUCIqsjek0MZ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Velocity Step Response Characteristics:\nRise Time: 0.2990 s\nSettling Time: 1.0167 s\nOvershoot: 9.9728 %\nSteady-state value: 1.4286\n"},"children":[],"key":"pxUw4ueMTH"}],"key":"eL1l0WkMxG"}],"key":"L1XjiA7vqI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"frequency response","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QNBFhq32EZ"}],"identifier":"frequency-response","label":"frequency response","html_id":"frequency-response","implicit":true,"key":"bHyrZSi4xI"}],"key":"c3R5n08hgE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Bode Plot\nplt.figure(figsize=(10, 8))\nct.bode_plot(G, dB=True, Hz=False, deg=True)\nplt.suptitle('Bode Diagram')\nplt.savefig('bode_plot.png')\n","key":"dQkP1c3pOd"},{"type":"outputs","id":"wh9ejoElwzDAA8cOnaWFj","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"d7c46c03354257144eb0b257678bc280","path":"/d7c46c03354257144eb0b257678bc280.png"},"text/plain":{"content":"<Figure size 1000x800 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"DRUH942LYr"}],"key":"xR0L6rFwrZ"}],"key":"t3tguPXW4G"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Stability Margins\ngm, pm, wg, wp = ct.margin(G)\nprint(f\"Gain Margin: {gm:.4f} (at {wg:.4f} rad/s)\")\nprint(f\"Phase Margin: {pm:.4f} deg (at {wp:.4f} rad/s)\")","key":"rQbsmuSIwW"},{"type":"outputs","id":"gsxIuLnCTlea6RxXLTT2-","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Gain Margin: inf (at nan rad/s)\nPhase Margin: 120.0000 deg (at 2.4056 rad/s)\n"},"children":[],"key":"pfZQuhP6GH"}],"key":"e6lN0PybyY"}],"key":"aOm7a5cmoK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Nyquist Plot\nplt.figure(figsize=(8, 8))\nct.nyquist_plot(G)\nplt.title('Nyquist Diagram')\nplt.savefig('nyquist_plot.png')\n\n","key":"uDJEUqZtF0"},{"type":"outputs","id":"0RiDB-Dzm3_1ZsJAMzaRT","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a49a488dd1b2988c580a72a3a55430c3","path":"/a49a488dd1b2988c580a72a3a55430c3.png"},"text/plain":{"content":"<Figure size 800x800 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"sibStT7alF"}],"key":"DRZ2s2Fxfc"}],"key":"UczE7OLccJ"}],"key":"c7FhJ3ecpn"},"references":{"cite":{"order":[],"data":{}}}}